{
    "name": "pingram/php",
    "version": "0.1.0",
    "description": "Official PHP SDK for Pingram - Send notifications via Email, SMS, Push, In-App, and more",
    "keywords": [
        "pingram",
        "notificationapi",
        "notification",
        "sdk",
        "email",
        "sms",
        "push",
        "in-app"
    ],
    "homepage": "https://www.pingram.io",
    "license": "MIT",
    "authors": [
        {
            "name": "Pingram",
            "homepage": "https://www.pingram.io"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "guzzlehttp/guzzle": "^7.3",
        "guzzlehttp/psr7": "^1.7 || ^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^8.0 || ^9.0",
        "friendsofphp/php-cs-fixer": "^3.5"
    },
    "autoload": {
        "psr-4": {
            "Pingram\\": "lib/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pingram\\Test\\": "test/"
        }
    },
    "support": {
        "docs": "https://www.pingram.io/docs",
        "source": "https://github.com/pingram-io/pingram-php"
    }
}